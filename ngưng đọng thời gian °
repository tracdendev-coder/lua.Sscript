--[[
    MÃ NGUỒN: TỰ ĐỘNG CHUYỂN ĐỔI DECAL ID SANG ASSET ID & PRELOAD ẢNH
    HƯỚNG DẪN DÁN: Thay thế toàn bộ mã nguồn cũ trong 'LocalScript'.
    SỬA ĐỔI CHÍNH: 
    - Nhận diện lý do ảnh bị tệp trắng/trong suốt: ID `99681486984720` là Decal ID (trang web), không phải Asset Texture ID thực tế khi render.
    - Dùng `MarketplaceService:GetProductInfo()` để tự động lấy đúng Asset ID ảnh gốc từ Roblox Server.
    - Dùng `ContentProvider:PreloadAsync()` để ép game tải xong hình ảnh trước khi hiển thị nút.
--]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local MarketplaceService = game:GetService("MarketplaceService")
local ContentProvider = game:GetService("ContentProvider")
local LocalPlayer = Players.LocalPlayer

-- Khởi tạo ScreenGui
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "TimeDilationGui"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

-- Nút bấm hình tròn ImageButton
local MainButton = Instance.new("ImageButton")
MainButton.Name = "MainButton"
MainButton.Size = UDim2.new(0, 110, 0, 110)
MainButton.Position = UDim2.new(0.05, 0, 0.4, 0)
MainButton.BackgroundTransparency = 1
MainButton.ScaleType = Enum.ScaleType.Fit
MainButton.Active = true
MainButton.Draggable = true 
MainButton.Parent = ScreenGui

-- Xử lý lấy đúng Asset ID từ Decal ID
local RAW_ID = 99681486984720
task.spawn(function()
    local success, result = pcall(function()
        return MarketplaceService:GetProductInfo(RAW_ID, Enum.InfoType.Asset)
    end)
    
    local finalImageId = "rbxassetid://" .. tostring(RAW_ID)
    if success and result and result.AssetId then
        finalImageId = "rbxassetid://" .. tostring(result.AssetId)
    end
    
    MainButton.Image = finalImageId
    -- Ép tải tài nguyên ảnh vào bộ nhớ đệm
    pcall(function()
        ContentProvider:PreloadAsync({MainButton})
    end)
end)

