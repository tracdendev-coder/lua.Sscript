StatusText.Position = UDim2.new(0, 10, 0, 0)
StatusText.ZIndex = 2
StatusText.Parent = SwitchBg

-- Chấm tròn trượt
local CircleSlider = Instance.new("Frame")
CircleSlider.Size = UDim2.new(0, 22, 0, 22)
CircleSlider.Position = UDim2.new(0, 3, 0, 3) -- Trái = TẮT
CircleSlider.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
CircleSlider.ZIndex = 3
CircleSlider.Parent = SwitchBg
Instance.new("UICorner", CircleSlider).CornerRadius = UDim.new(1, 0)

-- Biến trạng thái
local isSwitchOn = false

-- Hàm cập nhật công tắc
local function updateSwitch()
    if isSwitchOn then
        SwitchBg.BackgroundColor3 = Color3.fromRGB(40, 167, 69) -- XANH = BẬT
        CircleSlider.Position = UDim2.new(1, -25, 0, 3)
        StatusText.Text = "BẬT"
        StatusText.Position = UDim2.new(0, -10, 0, 0)
        ImageLabel.Visible = true
    else
        SwitchBg.BackgroundColor3 = Color3.fromRGB(220, 53, 69) -- ĐỎ = TẮT
        CircleSlider.Position = UDim2.new(0, 3, 0, 3)
        StatusText.Text = "TẮT"
        StatusText.Position = UDim2.new(0, 10, 0, 0)
        ImageLabel.Visible = false
    end
end

-- Sự kiện bấm vào công tắc
SwitchBg.MouseButton1Click:Connect(function()
    isSwitchOn = not isSwitchOn
    updateSwitch()
end)

-- Khung hiển thị ảnh
local ImageLabel = Instance.new("ImageLabel")
ImageLabel.Size = UDim2.new(1, -20, 0, 210)
ImageLabel.Position = UDim2.new(0, 10, 0, 140)
ImageLabel.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
ImageLabel.ScaleType = Enum.ScaleType.Stretch
ImageLabel.BackgroundTransparency = 0.5
ImageLabel.Visible = false  -- Mặc định tắt
ImageLabel.Parent = MainFrame
Instance.new("UICorner", ImageLabel).CornerRadius = UDim.new(0, 6)

-- Hàm cập nhật ảnh
local function updateImage(inputString)
    inputString = inputString:gsub("%s+", "")
    if inputString == "" then return end
    if tonumber(inputString) then
        ImageLabel.Image = "rbxthumb://type=Asset&id=" .. inputString .. "&w=420&h=420"
    else
        ImageLabel.Image = inputString
    end
    -- Nếu công tắc đang bật, hiển thị ảnh mới
    if isSwitchOn then
        ImageLabel.Visible = true
    end
end

-- Load ảnh mặc định
updateImage(IDTextBox.Text)

-- Sự kiện khi nhập ID mới
IDTextBox.FocusLost:Connect(function(enterPressed)
    updateImage(IDTextBox.Text)
end)

-- Khởi tạo trạng thái ban đầu (TẮT)
updateSwitch()

print("✅ Script đã chạy! Dùng công tắc gạt để bật/tắt ảnh.")
